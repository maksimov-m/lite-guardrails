# Пример окружения. Скопируйте в .env и подставьте реальные значения:
#   cp .env.example .env
# Файл .env в git НЕ коммитится (см. .gitignore).
#
# Значения ниже читает и приложение (src/config.py), и docker-compose.
# Хосты postgres/redis — это имена сервисов в docker-сети. Для запуска
# приложения вне docker поменяйте их на localhost (и порт БД на 5433).

# ---------- Приложение (guardrails) ----------
# DSN PostgreSQL. Логин/пароль/имя БД должны совпадать с POSTGRES_* ниже.
DATABASE_URL=postgresql+psycopg2://guard:CHANGE_ME_DB_PASSWORD@postgres:5432/guard

# Redis — хранилище PII-маппингов (anonymize/deanonymize).
REDIS_URL=redis://redis:6379/0

# TTL PII-маппингов в секундах.
MAPPING_TTL_SECONDS=3600

# Токен админ-ручек (/admin/*). ОБЯЗАТЕЛЬНО сменить на длинный случайный!
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

# Число gunicorn-воркеров.
WORKERS=8

# ---------- Метрики (Prometheus) ----------
# Отдавать метрики на GET /metrics (opt-in для потребителя). false — ручка 404.
METRICS_ENABLED=true
# Скользящее окно агрегации метрик, сек (по умолчанию сутки).
METRICS_WINDOW_SECONDS=86400
# Кэш ответа /metrics, сек: реже — меньше нагрузка на БД от частого scrape.
METRICS_CACHE_SECONDS=15

# Сколько дней хранить логи прогонов (run_logs); старше — удаляются фоновой
# задачей. <= 0 — хранить бессрочно (не чистить).
LOG_RETENTION_DAYS=30

# ---------- Rate limit ----------
# Лимит запросов в минуту на API-ключ по умолчанию (персональный лимит ключа
# переопределяет). <= 0 — без ограничения. Счётчики хранятся в Redis.
RATE_LIMIT_DEFAULT_PER_MIN=60

# ---------- Лимиты ввода ----------
# Максимальная длина поля text (в символах) в запросах детекции/анонимизации.
# Длиннее — 422 ещё до детекции (защита от DoS большим вводом и смягчение ReDoS).
# ~16k символов ≈ 16 КБ ASCII / ~32 КБ кириллицы.
MAX_TEXT_LENGTH=16384

# ---------- CORS ----------
# Разрешённые origin/методы/заголовки (списком через запятую). По умолчанию всё
# открыто ("*") — удобно для внутреннего запуска. Для prod ужать до своих доменов,
# напр. CORS_ALLOW_ORIGINS=https://app.company.ru,https://admin.company.ru
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ---------- Frontend (admin UI) ----------
# Базовый URL API для UI (вшивается на сборке). Пусто = относительный путь через
# nginx-проксю (тот же origin). Задавать, только если фронт и бэк на разных хостах,
# напр. UI_API_BASE=https://api.example.com. В UI это значение можно переопределить.
UI_API_BASE=

# ---------- Postgres (docker-compose) ----------
POSTGRES_USER=guard
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=guard
